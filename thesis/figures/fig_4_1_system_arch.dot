digraph system_arch {
	compound=true fontname="Microsoft YaHei" fontsize=11 nodesep=0.35 rankdir=TB
	node [fontname="Microsoft YaHei" fontsize=10 shape=box style="filled,rounded"]
	subgraph cluster_front {
		fillcolor="#FFF8E1" fontname="Microsoft YaHei" fontsize=11 label="前端（浏览器）" style=filled
		ui [label="仪表盘 UI" fillcolor="#FFECB3"]
		aw [label=AudioWorklet fillcolor="#FFECB3"]
		vad [label="VAD 监听" fillcolor="#FFECB3"]
	}
	subgraph cluster_trans {
		fillcolor="#E0F7FA" fontname="Microsoft YaHei" fontsize=11 label="传输" style=filled
		ws [label="WebSocket
（FastAPI）" fillcolor="#B2EBF2"]
	}
	subgraph cluster_back {
		fillcolor="#E8F5E9" fontname="Microsoft YaHei" fontsize=11 label="后端（Python + asyncio）" style=filled
		subgraph cluster_pipe {
			fontname="Microsoft YaHei" fontsize=10 label="Pipeline 编排"
			pipe [label=VoiceChatPipeline fillcolor="#A5D6A7"]
		}
		stt [label="StreamingRecognizer
（阿里云 NLS）" fillcolor="#BBDEFB"]
		rag [label="DocumentStore
（FAISS+BM25+Rerank）" fillcolor="#C8E6C9"]
		llm [label="StreamingGenerator
（Qwen-Plus）" fillcolor="#FFCCBC"]
		tts [label="StreamingSynthesizer
（CosyVoice）" fillcolor="#F8BBD0"]
	}
	subgraph cluster_idx {
		fillcolor="#F3E5F5" fontname="Microsoft YaHei" fontsize=11 label="持久化索引" style=filled
		faiss [label="FAISS IndexFlatIP" fillcolor="#E1BEE7"]
		bm25 [label=BM25Okapi fillcolor="#E1BEE7"]
		meta [label="documents.json" fillcolor="#E1BEE7"]
	}
	ui -> ws
	aw -> ws [label="PCM/base64"]
	vad -> ws [label="打断信号"]
	ws -> pipe
	pipe -> stt
	pipe -> rag
	pipe -> llm
	pipe -> tts
	rag -> faiss
	rag -> bm25
	rag -> meta
}
